{
  "name": "@vitejs/release-scripts",
  "version": "1.6.0",
  "description": "@vitejs release scripts",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitejs/release-scripts.git"
  },
  "scripts": {
    "build": "rolldown -c",
    "test": "vitest",
    "prettier": "pnpm prettier-ci --write",
    "prettier-ci": "prettier --cache --ignore-path=.gitignore --check '**/*.{ts,json,md,yml}'",
    "qa": "tsc && pnpm prettier-ci && pnpm build && vitest run",
    "release": "node scripts/release.ts"
  },
  "dependencies": {
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "mri": "^1.2.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "publint": "^0.3.18",
    "semver": "^7.7.4",
    "tinyexec": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.7.1",
    "fs-fixture": "^2.13.0",
    "prettier": "^3.8.3",
    "rolldown": "^1.0.0-rc.16",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.0"
}
